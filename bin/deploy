#!/bin/bash
set -e

APP_DIR="/var/www/k5"
cd $APP_DIR

echo "=== git pull ==="
git pull origin main

echo "=== bundle install ==="
bundle install --without development test

echo "=== yarn install ==="
yarn install

echo "=== アセットビルド ==="
RAILS_ENV=production bundle exec rails assets:precompile

echo "=== DBマイグレーション ==="
RAILS_ENV=production bundle exec rails db:migrate

echo "=== Puma再起動 ==="
sudo systemctl restart k5

echo "=== デプロイ完了 ==="
