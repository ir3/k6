= form_for @stock do |f|
  - if @stock.errors.any?
    #error_explanation
      %h2= "#{pluralize(@stock.errors.count, "error")} prohibited this stock from being saved:"
      %ul
        - @stock.errors.full_messages.each do |msg|
          %li= msg

  .field
    = f.label :id
    = f.number_field :id
  .field
    = f.label :partno
    = f.text_field :partno
  .field
    = f.label :kind
    = f.number_field :kind
  .field
    = f.label :indate
    = f.date_select :indate
  .field
    = f.label :num
    = f.number_field :num
  .field
    = f.label :inprice
    = f.number_field :inprice
  .field
    = f.label :irprice
    = f.number_field :irprice
  .field
    = f.label :invalue
    = f.number_field :invalue
  .field
    = f.label :irvalue
    = f.number_field :irvalue
  .field
    = f.label :outdate
    = f.date_select :outdate
  .field
    = f.label :onum
    = f.number_field :onum
  .field
    = f.label :mno
    = f.number_field :mno
  .field
    = f.label :orprice
    = f.number_field :orprice
  .field
    = f.label :orvalue
    = f.number_field :orvalue
  .field
    = f.label :itemno
    = f.text_field :itemno
  .field
    = f.label :cordno
    = f.text_field :cordno
  .field
    = f.label :updated_at
    = f.datetime_select :updated_at
  .field
    = f.label :memo
    = f.text_field :memo
  .field
    = f.label :cname
    = f.text_field :cname
  .field
    = f.label :sname
    = f.text_field :sname
  .field
    = f.label :ikubun
    = f.number_field :ikubun
  .field
    = f.label :okubun
    = f.number_field :okubun
  .field
    = f.label :created_at
    = f.datetime_select :created_at
  .field
    = f.label :deleted_at
    = f.datetime_select :deleted_at
  .actions
    = f.submit 'Save'
