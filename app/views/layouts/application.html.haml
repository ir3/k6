!!!
%html
  %head
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title= content_for(:title) || "K2"
    %meta{:content => "width=device-width,initial-scale=1", :name => "viewport"}/
    %meta{:content => "yes", :name => "apple-mobile-web-app-capable"}/
    %meta{:content => "yes", :name => "mobile-web-app-capable"}/
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    %link{:href => "/icon.png", :rel => "icon", :type => "image/png"}/
    %link{:href => "/icon.svg", :rel => "icon", :type => "image/svg+xml"}/
    %link{:href => "/icon.png", :rel => "apple-touch-icon"}/
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = stylesheet_link_tag "k", "data-turbo-track": "reload"
    = javascript_include_tag "application", "data-turbo-track": "reload", type: "module"
  %body
    .navbar.bg-blue-900.text-white{style: "min-height: calc(4rem - 4px); padding-top: 0; padding-bottom: 0;"}
      %a.btn.btn-ghost.normal-case.text-xl.text-white ようこそ
      - if content_for?(:page_title)
        %span.text-white.text-lg.ml-2= yield(:page_title)
      -if authenticated?
        -user = User.find(Current.user.id)
        =link_to "#{Current.user.email_address}さん", user_path(user), class: "ml-8"
        -if user.user_profile
          -if user.user_profile.read_attribute_before_type_cast(:state) > 1
            .dropdown
              %label.btn.btn-sm.btn-secondary{tabindex: "0"} 管理者 ▾
              %ul.dropdown-content.menu.bg-base-100.rounded-box.z-10.w-40.p-2.shadow.text-black{tabindex: "0"}
                %li= link_to "ユーザ一覧", users_path
                %li= link_to "ユーザprofile一覧", user_profiles_path
        = button_to "利用終了", session_path, method: :delete, class: "btn btn-error btn-sm text-white"
      -else
        %a.btn.btn-ghost.normal-case.text-xl
        = link_to "利用開始", sign_up_path
      .flex-none
        %ul.menu.menu-horizontal.px-4
          %li
            = link_to "Home", welcom_index_path
          %li
            %a About
          %li
            %a Contact
    = tag.div(flash[:alert], style: "color:red") if flash[:alert]
    - if flash[:reset_url]
      = tag.div(style: "color:green") do
        = link_to "▶ パスワードリセットはこちら", flash[:reset_url]
    = yield
