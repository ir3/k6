- content_for :head do
  %script{src: "https://cdn.jsdelivr.net/npm/@ruby/4.0-wasm-wasi@2.9.3-2.9.4/dist/browser.script.iife.js"}
  %script{src: "https://cdn.jsdelivr.net/npm/p5@1.11.3/lib/p5.js"}
  %script{src: "/p5.rb", type: "text/ruby"}
  :plain
    <script type="text/ruby">
    class App
      def setup
        createCanvas(720, 300)
        colorMode(HSB, 360, 100, 100, 255)
        textAlign(CENTER, CENTER)
        textSize(36)
        @decorated    = false
        @prev_pressed = false
      end

      def draw
        pressed = mouseIsPressed == JS::True
        if pressed && !@prev_pressed
          @decorated = !@decorated
        end
        @prev_pressed = pressed

        background(0, 0, 8)

        cx = width / 2
        cy = height / 2
        tw = 440
        th = 70

        if @decorated
          noFill()
          8.times do |i|
            hue   = (frameCount * 2 + i * 10) % 360
            alpha = map(i, 0, 7, 25, 200).to_i
            sw    = map(i, 0, 7, 16, 1)
            stroke(hue, 80, 100, alpha)
            strokeWeight(sw)
            rect(cx - (tw + i * 6) / 2, cy - (th + i * 6) / 2, tw + i * 6, th + i * 6, 6)
          end

          noFill()
          stroke(60, 20, 100, 255)
          strokeWeight(1.5)
          rect(cx - tw / 2, cy - th / 2, tw, th, 6)

          perimeter = (tw + th) * 2
          5.times do |i|
            pos = (frameCount * 0.1 + i * (perimeter / 5)) % perimeter
            px, py = perimeter_pos(cx - tw / 2, cy - th / 2, tw, th, pos)
            hue = (frameCount * 3 + i * 72) % 360
            noStroke()
            fill(hue, 90, 100, 230)
            circle(px, py, 8)
            fill(hue, 60, 100, 100)
            circle(px, py, 16)
          end
        end

        noStroke()
        fill(60, 10, 100, 255)
        text("ようこそ ユーザ登録してください", cx, cy)
      end

      def perimeter_pos(x0, y0, w, h, pos)
        if pos < w
          [x0 + pos, y0]
        elsif pos < w + h
          [x0 + w, y0 + (pos - w)]
        elsif pos < w * 2 + h
          [x0 + w - (pos - w - h), y0 + h]
        else
          [x0, y0 + h - (pos - w * 2 - h)]
        end
      end
    end

    JS.global[:__p5_container] = JS.global[:document].call(:getElementById, "p5-canvas")
    P5::init(App.new)
    </script>

#p5-canvas{style: "display:flex; justify-content:center;"}
%div{style: "display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:calc(100vh - 4rem)"}
  .container{style: "margin: 25px auto"}
    = form_with model: @user, url: sign_up_path do |form|
      - if form.object.errors.any?
        %div
        Error: #{form.object.errors.full_messages.first}
      %table.center-table.radius-table
        %thead.neutral
          %tr
            %th.bg-primary.text-primary-content= form.label :email_address
            %td.text-primary-content{width:"380px"}= form.email_field :email_address, required: true, autocomplete: "email", autofocus: true
          %tr
            %th.bg-primary.text-primary-content= form.label :password
            %td= form.password_field :password, required: true, autocomplete: "new-password"
          %tr
            %th.bg-primary.text-primary-content= form.label :password_confirmation
            %td= form.password_field :password_confirmation, required: true, autocomplete: "new-password"
          %tr
            %td
            %td= form.submit "登録", class: "btn btn-primary"
          %tr
            %td
            %td= link_to "すでにアカウントをお持ちの方は利用開始", new_session_path, class: "link link-primary text-sm"
