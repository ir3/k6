= form_for @registry do |f|
  - if @registry.errors.any?
    #error_explanation
      %h2= "#{pluralize(@registry.errors.count, "error")} prohibited this registry from being saved:"
      %ul
        - @registry.errors.full_messages.each do |msg|
          %li= msg

  .field
    = f.label :countryid
    = f.text_field :countryid
  .field
    = f.label :country
    = f.text_field :country
  .field
    = f.label :rate
    = f.text_field :rate
  .field
    = f.label :deleted_at
    = f.datetime_select :deleted_at
  .actions
    = f.submit 'Save'
