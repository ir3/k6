= form_for @kepart do |f|
  - if @kepart.errors.any?
    #error_explanation
      %h2= "#{pluralize(@kepart.errors.count, "error")} prohibited this kepart from being saved:"
      %ul
        - @kepart.errors.full_messages.each do |msg|
          %li= msg

  .field
    = f.label :pcode
    = f.text_field :pcode
  .field
    = f.label :form
    = f.text_field :form
  .field
    = f.label :size
    = f.text_field :size
  .field
    = f.label :jname
    = f.text_field :jname
  .field
    = f.label :ename
    = f.text_field :ename
  .field
    = f.label :newprice
    = f.number_field :newprice
  .field
    = f.label :price
    = f.number_field :price
  .field
    = f.label :stock
    = f.number_field :stock
  .field
    = f.label :sel_unit
    = f.text_field :sel_unit
  .field
    = f.label :weightkg
    = f.text_field :weightkg
  .field
    = f.label :munit
    = f.number_field :munit
  .field
    = f.label :itemno
    = f.text_field :itemno
  .field
    = f.label :cordno
    = f.text_field :cordno
  .field
    = f.label :comment
    = f.text_field :comment
  .field
    = f.label :created_at
    = f.datetime_select :created_at
  .field
    = f.label :updated_at
    = f.datetime_select :updated_at
  .field
    = f.label :deleted_at
    = f.datetime_select :deleted_at
  .actions
    = f.submit 'Save'
