%table
  %tr
    %td{style:'text-align:center; font-size:xx-large'}
      注文部品詳細
    %td{style:"padding: 5px 5px 5px 30px;"}
      %form{method:"post", action: "#{orders_keycopy_path}", name: "order_key_copy"}
        = hidden_field_tag('authenticity_token', form_authenticity_token)
        %input{type: "submit", value: "取引先、船名、機番を複製し新規取引登録", class: "btn wtext btn-info"}
    %td{style:"padding: 5px 5px 5px 30px;"}
      %form{method:"post", action: "#{orders_copy_path}", name: "order_copy"}
        = hidden_field_tag('authenticity_token', form_authenticity_token)
        %input{type: "submit", value: "部品詳細も複製し新規取引登録",  class: "btn wtext btn-info"}
    %td{style:"padding: 5px 5px 5px 30px;"}
      = link_to "台帳を修正", edit_order_path,  class: "btn wtext btn-info"
    %td{style:"padding: 5px 5px 5px 30px;"}
      = link_to "台帳から削除", order_path, method: :delete, data: {confirm: "本当に削除しますか？"}, class: "btn wtext btn-info"
%table.center-table.radius-table{width: "99%", align:"center"}
  %tr
    %th.bg-primary.text-primary-content{width:"40px"} Id
    %td{width:"70px"}= @order.id
    %th.bg-primary.text-primary-content{width:"150px"} 取引管理No.
    %td{width:"120px",style:'text-align:center; font-size:xx-large'}= @order.mno
    %th.bg-primary.text-primary-content{width:"90px"} 会社名
    %td{style:'text-align:center; font-size:x-large'}
      - dp = ''
      - adlist = Adlist.find_by(no: @order.adlist_id.to_s)
      - if adlist
        - dp << adlist.company
        - dp << ' '+adlist.section if adlist.section
        = link_to dp, adlist
    %th.bg-primary.text-primary-content{width:"60px"} 船名
    %td{style:'text-align:center; font-size:xx-large'}
      = @order.shipname
    %th.bg-primary.text-primary-content{width:"60px"} 船籍
    %td{style:'text-align:center; font-size:xx-large'}
      = @order.country
%table.center-table.radius-table{width: "99%", align:"center"}
  %tr
    %th.bg-primary.text-primary-content{width:"60px"} 件名
    %td= @order.orderitem
    %th.bg-primary.text-primary-content{width:"60px"} 内容
    %td= @order.memo
    %th.bg-primary.text-primary-content{width:"60px"} 機番
    %td{width:"160px",style:'text-align:center; font-size:xx-large'}
      = @order.engno
    %th.bg-primary.text-primary-content{width:"150px"} 型式(機種)
    %td{width:"120px",style:'text-align:center; font-size:x-large'}
      = @order.etype
    %th.bg-primary.text-primary-content{width:"100px"} 客先註番
    %td= @order.ono
%table.center-table.radius-table{width: "99%", align:"center"}
  %tr
    %th.bg-primary.text-primary-content{width:"40px"} TC
    %td= @order.tc
    %th.bg-primary.text-primary-content{width:"55px"} TCNo.
    %td= @order.tcno
    %th.bg-primary.text-primary-content{width:"40px"} ZP
    %td= @order.zp
    %th.bg-primary.text-primary-content{width:"55px"} ZPNo.
    %td= @order.zpno
    %th.bg-primary.text-primary-content{width:"40px"} GLC
    %td= @order.glc
    %th.bg-primary.text-primary-content{width:"55px"} GLNo.
    %td= @order.glcno
    %th.bg-primary.text-primary-content{width:"40px"} MG
    %td= @order.mg
    %th.bg-primary.text-primary-content{width:"55px"} MGNo.
    %td= @order.mgno
%table.center-table.radius-table{width: "99%", align:"center"}
  %tr
    %th.bg-primary.text-primary-content{width:"100px"} 納入期日
    %td{width:"150px"}= @order.rdate
    %th.bg-primary.text-primary-content{width:"160px"} 納入コメント
    %td= @order.ncomment
    %th.bg-primary.text-primary-content{width:"80px"} 点数
    %td= @order.pnum
    %th.bg-primary.text-primary-content{width:"150px"} A部品掛け率
    %td{width:"80px"}= @order.irate
    %th.bg-primary.text-primary-content{width:"140px"}  以外掛け率
    %td{width:"80px"}= @order.irate2
    %th.bg-primary.text-primary-content{width:"80px"} 値引き
    %td= @order.nebiki
    %th.bg-primary.text-primary-content{width:"100px"} 更新日時
    %td.datej= @order.updated_at.strftime("%Y/%m/%d %H:%M")
%table
  %tr
    %td
      見積依頼出力日
    %td
      = @order.ndate
      %br
        初回見積出力日
      %br= @order.mitday
    %td
      最新見積出力日
      %br= @order.ldate
    %td
      受注or受注メモ出力日
      %br= @order.tcondition
    %td
      納品or納品書(請求要となった)日
      %br= @order.pnum
    %td
      出荷案内出力(請求要となった)日
      %br= @order.syuday
    %td
      請求or請求書出力日
      %br= @order.seiday
    %td
      入金(確認)日
%table.center-table.radius-table{width: "99%", align:"center"}
  %thead.bg-primary.text-primary-content
    %tr
      %th{width:"100px"} id
      %th{width:"25px"} 順
      %th{width:"140px"} 部品コード
      %th{width:"100px"} ItemNo
      %th{width:""} 名称
      %th{width:""} 備考
      %th{width:"60px"} 数量
      %th{width:"120px"} 販売単価(円)
      %th{width:"110px"} 単位重量kg
      %th{width:"90px"} 総重量kg
      %th{width:"80px"} (掛率)
      %th{width:"180px"} 更新日時
  %tbody
  - @orderparts.each do |orderpart|
    %tr
      %td= orderpart.id
      %td{style:'text-align:right'}= orderpart.sno
      - if Part.find_by(pcode: orderpart.partno)
        - part_id = Part.find_by(pcode: orderpart.partno).id
        %td= (link_to orderpart.partno, parts_path+"/#{part_id}")+ orderpart.kzaiko
      - elsif Kepart.find_by(pcode: orderpart.partno)
        - part_id = Kepart.find_by(pcode: orderpart.partno).id
        %td= (link_to orderpart.partno, keparts_path+"/#{part_id}")+ orderpart.kzaiko
      - else
        %td= ''
      %td= orderpart.itemno
      - #part = Part.find_by_sql("SELECT jname FROM parts WHERE pcode = '#{orderpart.partno}'")
      - part = Part.find_by(pcode: orderpart.partno)
      %td= part.jname if part
      %td= orderpart.info
      %td{style:'text-align:right'}= orderpart.qty
      %td{style:'text-align:right'}= orderpart.unitpd.to_s.gsub(/(?<=\d)(?=(?:\d{3})+(?!\d))/, ',')
      %td{style:'text-align:right'}= orderpart.unitweight
      %td{style:'text-align:right'}= orderpart.totalweight
      %td{style:'text-align:right'}= orderpart.irate
      %td= orderpart.updated_at.strftime('%Y/%m/%d %H:%M')
