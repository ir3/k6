            %input.tb1.btn.wtext.btn-info{title: "１．新潟標準部品  （NDPからの Excel価格表データに存在する）の変化分（最近 増えている）\r\n２．新潟非標準部品（非定常品 注文にて調達。Excelにはないが新潟部品）\r\n３．一般標準部品  （新潟純正ではないが、新潟部品番号にて関連して取り扱い）\r\n４．他社部品      （ヤンマー部品など）\r\n   ", type: "submit", value: "Ｂ部品"}/
        %td
          %form{action: "hiteijolist.asp", method: "post"}
          %input.input.input-bordered.border-2.border-neutral.bg-base-100{name: "sNAME", size: "12", style: "ime-mode:disabled;", type: "text", value: ""}/
          %br/
          %input.btn.wtext.btn-info{type: "submit", value: "形式検索"}/
        %td
          %form{action: "hiteijolist.asp", method: "post"}
          %input.input.input-bordered.border-2.border-neutral.bg-base-100{name: "JNAME", size: "12", type: "text", value: ""}/
          %br/
          %input.btn.wtext.btn-info{type: "submit", value: "和文検索"}/
        %td
