= form_with(model: user_profile) do |form|
  - if user_profile.errors.any?
    %div{style: "color: red"}
      %h2= "#{pluralize(user_profile.errors.count, "error")} prohibited this user_profile from being saved:"

      %ul
        - user_profile.errors.each do |error|
          %li= error.full_message

  %div
    = form.submit
